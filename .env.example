#
# Runtime
#
NODE_ENV=development

#
# Logging
#
LOG_LEVEL=info
LOG_FORMAT=pretty
LOG_DIR=./logs
LOG_LLM_CONTENT_ENABLED=false
LOG_LLM_CONTENT_MAX_CHARS=4000

#
# Database
# DB_CLIENT: sqlite | mysql
#
DB_CLIENT=sqlite
DB_SQLITE_PATH=./data/novel.db

#
# Default provider
# LLM_PROVIDER: mock | openai | anthropic | custom
#
LLM_PROVIDER=mock

#
# Mock provider
# MOCK_LLM_MODE: echo | fixture | json
#
MOCK_LLM_MODE=echo
MOCK_LLM_RESPONSE_TEXT=Mock response
MOCK_LLM_FIXTURE_PATH=
MOCK_LLM_MODEL=mock-v1

#
# OpenAI provider
#
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4-mini

#
# Anthropic provider
#
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

#
# Custom provider
#
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_MODEL=custom-default
