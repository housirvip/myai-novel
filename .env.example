# Copy this file to .env and fill in your real values.

# --- LLM provider selection ---
LLM_PROVIDER=openai

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5

# Optional stage-based overrides
# LLM_PLANNING_PROVIDER=openai
# LLM_PLANNING_MODEL=gpt-5
# LLM_GENERATION_PROVIDER=openai
# LLM_GENERATION_MODEL=gpt-5
# LLM_REVIEW_PROVIDER=openai
# LLM_REVIEW_MODEL=gpt-5
# LLM_REWRITE_PROVIDER=openai
# LLM_REWRITE_MODEL=gpt-5

# Optional second provider (OpenAI-compatible gateway)
# OPENAI_COMPATIBLE_API_KEY=your_compatible_provider_key_here
# OPENAI_COMPATIBLE_BASE_URL=https://your-compatible-provider.example/v1
# OPENAI_COMPATIBLE_MODEL=your-compatible-model

# --- Database backend selection ---
# Project runtime backend is chosen from config/database.json.
# Supported targets in v5 planning are sqlite or mysql.
# SQLite remains the default and currently wired path.
# MySQL config shape (for future project config use):
# {
#   "database": {
#     "client": "mysql",
#     "host": "127.0.0.1",
#     "port": 3306,
#     "user": "root",
#     "password": "secret",
#     "database": "myai_novel"
#   }
# }
    