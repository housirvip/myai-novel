#
# Runtime
#
NODE_ENV=development

#
# Logging
#
LOG_LEVEL=info
LOG_FORMAT=pretty
LOG_DIR=./logs
LOG_LLM_CONTENT_ENABLED=false
LOG_LLM_CONTENT_MAX_CHARS=4000

#
# Database
# DB_CLIENT: sqlite | mysql
#
DB_CLIENT=sqlite
DB_SQLITE_PATH=./data/novel.db
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=myai_novel
DB_USER=root
DB_PASSWORD=
DB_POOL_MAX=10

#
# Default provider
# LLM_PROVIDER: mock | openai | anthropic | custom
#
LLM_PROVIDER=mock

#
# Mock provider
# MOCK_LLM_MODE: echo | fixture | json
#
MOCK_LLM_MODE=echo
MOCK_LLM_RESPONSE_TEXT=Mock response
MOCK_LLM_FIXTURE_PATH=
MOCK_LLM_MODEL=mock-v1
LLM_DEFAULT_MAX_TOKENS=2048

#
# OpenAI provider
#
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4-mini

#
# Anthropic provider
#
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

#
# Custom provider
#
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_MODEL=custom-default

#
# Planning and retrieval limits
#
PLANNING_KEYWORD_MAX_LENGTH=8
PLANNING_INTENT_KEYWORD_LIMIT=20
PLANNING_INTENT_MUST_INCLUDE_LIMIT=20
PLANNING_INTENT_MUST_AVOID_LIMIT=20
PLANNING_RETRIEVAL_OUTLINE_LIMIT=3
PLANNING_RETRIEVAL_RECENT_CHAPTER_LIMIT=3
PLANNING_RETRIEVAL_RECENT_CHAPTER_SCAN_MULTIPLIER=5
PLANNING_RETRIEVAL_HOOK_LIMIT=10
PLANNING_RETRIEVAL_CHARACTER_LIMIT=12
PLANNING_RETRIEVAL_FACTION_LIMIT=8
PLANNING_RETRIEVAL_ITEM_LIMIT=8
PLANNING_RETRIEVAL_RELATION_LIMIT=10
PLANNING_RETRIEVAL_WORLD_SETTING_LIMIT=8
PLANNING_RETRIEVAL_ENTITY_SCAN_LIMIT=200
PLANNING_RETRIEVAL_RERANKER=none
PLANNING_RETRIEVAL_EMBEDDING_PROVIDER=hash
PLANNING_RETRIEVAL_EMBEDDING_ENABLED=false
PLANNING_RETRIEVAL_EMBEDDING_SEARCH_MODE=basic

#
# Custom embedding provider (OpenAI-compatible /embeddings)
#
CUSTOM_EMBEDDING_BASE_URL=
CUSTOM_EMBEDDING_API_KEY=
CUSTOM_EMBEDDING_MODEL=custom-embedding-v1
CUSTOM_EMBEDDING_PATH=/embeddings
