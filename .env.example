# Copy this file to .env and fill in your real values.

# --- LLM provider selection ---
LLM_PROVIDER=openai
LLM_TIMEOUT_MS=60000
LLM_MAX_RETRIES=1

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5
OPENAI_TIMEOUT_MS=60000
OPENAI_MAX_RETRIES=1

# Optional stage-based overrides
# LLM_PLANNING_PROVIDER=openai
# LLM_PLANNING_MODEL=gpt-5
# LLM_PLANNING_TIMEOUT_MS=45000
# LLM_PLANNING_MAX_RETRIES=1
# LLM_GENERATION_PROVIDER=openai
# LLM_GENERATION_MODEL=gpt-5
# LLM_GENERATION_TIMEOUT_MS=90000
# LLM_GENERATION_MAX_RETRIES=1
# LLM_REVIEW_PROVIDER=openai
# LLM_REVIEW_MODEL=gpt-5
# LLM_REVIEW_TIMEOUT_MS=60000
# LLM_REVIEW_MAX_RETRIES=1
# LLM_REWRITE_PROVIDER=openai
# LLM_REWRITE_MODEL=gpt-5
# LLM_REWRITE_TIMEOUT_MS=90000
# LLM_REWRITE_MAX_RETRIES=1

# Optional second provider (OpenAI-compatible gateway)
# OPENAI_COMPATIBLE_API_KEY=your_compatible_provider_key_here
# OPENAI_COMPATIBLE_BASE_URL=https://your-compatible-provider.example/v1
# OPENAI_COMPATIBLE_MODEL=your-compatible-model
# OPENAI_COMPATIBLE_TIMEOUT_MS=60000
# OPENAI_COMPATIBLE_MAX_RETRIES=1

# Minimal OpenAI-compatible default example:
# LLM_PROVIDER=openai-compatible
# OPENAI_COMPATIBLE_API_KEY=sk-your-key
# OPENAI_COMPATIBLE_BASE_URL=https://your-compatible-provider.example/v1
# OPENAI_COMPATIBLE_MODEL=your-compatible-model

# --- Database backend selection ---
# Project runtime backend is chosen from config/database.json.
# Supported targets are sqlite or mysql.
# Minimal SQLite init example:
# novel init --title "测试之书" --genre "奇幻" --db-client sqlite --db-filename data/novel.sqlite
#
# Minimal MySQL init example:
# novel init --title "测试之书" --genre "奇幻" --db-client mysql --db-host 127.0.0.1 --db-port 3306 --db-user root --db-password secret --db-name myai_novel
#
# MySQL config shape in config/database.json:
# {
#   "database": {
#     "client": "mysql",
#     "host": "127.0.0.1",
#     "port": 3306,
#     "user": "root",
#     "password": "secret",
#     "database": "myai_novel"
#   }
# }