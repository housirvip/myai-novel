{
  "name": "myai-novel",
  "version": "0.1.0",
  "private": true,
  "description": "AI novel CLI tool built with TypeScript, Node.js, SQLite, and pluggable LLM providers.",
  "type": "module",
  "bin": {
    "novel": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "find test -name '*.test.ts' -print0 | xargs -0 ./node_modules/.bin/tsx --test",
    "test:mysql": "./node_modules/.bin/tsx --test test/integration/mysql-workflow.test.ts test/integration/db-parity.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "kysely": "^0.27.6",
    "mysql2": "^3.15.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
